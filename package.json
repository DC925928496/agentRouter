{
  "name": "agentrouter",
  "version": "0.1.2",
  "description": "Windows desktop app for switching Codex, Claude Code, and Gemini provider settings.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "package": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "local.agentrouter",
    "productName": "Agent Router",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "electronDist": "node_modules/electron/dist",
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
